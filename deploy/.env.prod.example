# NetBird Production Environment Variables
# Copy to .env and fill in actual values:  cp .env.prod.example .env

# Image version tag (from git tag or manual)
NETBIRD_VERSION=v0.67.1

# Dashboard UI version label + update check (GitHub dashboard release tag, e.g. v2.27.0).
# If unset, defaults to "latest" in the UI; the sidebar will not mis-flag updates for that tag.
DASHBOARD_UI_VERSION=v2.27.0

# Exposed HTTP port (default: 80)
NETBIRD_HTTP_PORT=80

# LDAP configuration (REQUIRED - no defaults for passwords in prod)
# Must match auth.connectors[].config.bindPW in ./config.yaml or NetBird cannot bind to LDAP.
LDAP_ORGANISATION="Your Company"
LDAP_DOMAIN=example.org
LDAP_ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
LDAP_BASE_DN=dc=example,dc=org
