# Copy this file to peer.env, then fill in NB_SETUP_KEY.
#
# Option A (interactive):
#   1. Open http://localhost
#   2. Login as ldapadmin@example.org / LdapAdmin@123 (LDAP) or admin@netbird.local / Admin@123 (after approving)
#   3. Setup Keys -> Create Setup Key (Reusable)
#   4. Paste it into NB_SETUP_KEY below
#
# Option B (one-shot, requires curl + jq):
#   ./scripts/bootstrap-setup-key.sh > /tmp/k && \
#     printf 'NB_SETUP_KEY=%s\nNB_HOSTNAME=docker-router\nNB_MANAGEMENT_URL=http://netbird-server\nNB_LOG_LEVEL=info\n' "$(cat /tmp/k)" > peer.env && rm /tmp/k

# Setup key from the dashboard. Required.
NB_SETUP_KEY=

# Hostname shown for this peer in the dashboard.
NB_HOSTNAME=docker-router

# Management URL the peer connects to (use docker network DNS).
NB_MANAGEMENT_URL=http://netbird-server

# Optional: set to debug for verbose logs
NB_LOG_LEVEL=info
